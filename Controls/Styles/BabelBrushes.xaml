<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="PrimaryBrush" Color="#0078D4" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#106EBE" />
    <SolidColorBrush x:Key="DangerBrush" Color="#D32F2F" />
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#B71C1C" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#555555" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#888888" />
    <SolidColorBrush x:Key="BorderBrush" Color="#D0D0D0" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FAFAFA" />

</ResourceDictionary>
