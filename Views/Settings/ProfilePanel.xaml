<UserControl x:Class="Babel.Views.Settings.ProfilePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Babel.Controls">
    <Grid>
        <StackPanel>
            <TextBlock Text="Profiles" Style="{StaticResource BabelSectionHeader}" />
            <Border Style="{StaticResource BabelSectionCard}">
                <StackPanel>
                    <!-- Profile selector row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <ComboBox ItemsSource="{Binding Profiles}"
                                  SelectedItem="{Binding SelectedProfile}"
                                  DisplayMemberPath="Name"
                                  Width="220"
                                  Style="{StaticResource BabelComboBoxStyle}"
                                  Visibility="{Binding Profiles.Count, Converter={StaticResource CountToVis}}" />
                        <TextBlock Text="No profiles."
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,8,0"
                                   Visibility="{Binding Profiles.Count, Converter={StaticResource CountToVis}, ConverterParameter=Invert}" />
                        <controls:BabelButton Style="{StaticResource BabelButtonSecondary}"
                                              Content="＋ New"
                                              Margin="8,0,0,0"
                                              Command="{Binding AddProfileCommand}" />
                        <controls:BabelButton Style="{StaticResource BabelButtonDanger}"
                                              Content="🗑"
                                              Margin="8,0,0,0"
                                              Padding="8,0"
                                              Command="{Binding DeleteProfileCommand}"
                                              CommandParameter="{Binding SelectedProfile}"
                                              Visibility="{Binding Profiles.Count, Converter={StaticResource CountToVis}}" />
                    </StackPanel>

                    <!-- Profile form -->
                    <StackPanel x:Name="FormPanel"
                                Visibility="{Binding SelectedProfile, Converter={StaticResource NullToVis}, ConverterParameter=Invert}">
                        <TextBlock Text="Profile Name" Style="{StaticResource BabelFormLabel}" />
                        <TextBox Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource BabelTextBoxStyle}"
                                 Margin="0,0,0,14" />

                        <TextBlock Text="API Key" Style="{StaticResource BabelFormLabel}" />
                        <PasswordBox x:Name="ApiKeyBox"
                                     Style="{StaticResource BabelPasswordBoxStyle}"
                                     Margin="0,0,0,14" />

                        <TextBlock Text="API Endpoint" Style="{StaticResource BabelFormLabel}" />
                        <TextBox Text="{Binding Endpoint, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource BabelTextBoxStyle}"
                                 Margin="0,0,0,14" />

                        <TextBlock Text="Model" Style="{StaticResource BabelFormLabel}" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"
                                      ItemsSource="{Binding AvailableModels}"
                                      IsEditable="True"
                                      IsTextSearchEnabled="True"
                                      Style="{StaticResource BabelComboBoxStyle}" />
                            <controls:BabelButton Style="{StaticResource BabelButtonIcon}"
                                                  Grid.Column="1"
                                                  Content="↻"
                                                  Margin="8,0,0,0"
                                                  Command="{Binding RefreshModelsCommand}" />
                        </Grid>

                        <TextBlock Text="Loading models..."
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,6,0,8"
                                   Visibility="{Binding IsLoadingModels, Converter={StaticResource BoolToVis}}" />

                        <TextBlock Text="{Binding ModelFetchError}"
                                   Foreground="{StaticResource DangerBrush}"
                                   FontSize="12"
                                   Margin="0,6,0,0"
                                   Visibility="{Binding HasModelFetchError, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <!-- Empty state -->
                    <TextBlock Text="Select or create a profile to configure."
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,20,0,0"
                               Visibility="{Binding SelectedProfile, Converter={StaticResource NullToVis}}" />
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="12"
                       Margin="0,0,0,12"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <controls:BabelButton Style="{StaticResource BabelButtonSecondary}"
                                      Content="Cancel"
                                      Margin="0,0,8,0"
                                      Command="{Binding CancelCommand}" />
                <controls:BabelButton Style="{StaticResource BabelButtonPrimary}"
                                      Content="Save"
                                      Command="{Binding SaveCommand}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
