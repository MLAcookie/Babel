<UserControl x:Class="Babel.Views.Settings.HomePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:Babel.Controls">
    <Grid>
        <StackPanel>
            <TextBlock Text="Home"
                       Style="{StaticResource BabelSectionHeader}" />

            <Border Style="{StaticResource BabelSectionCard}">
                <StackPanel>
                    <TextBlock Text="Active Profile"
                               Style="{StaticResource BabelFormLabel}" />
                    <ComboBox ItemsSource="{Binding Profiles}"
                              HorizontalAlignment="Left"
                              SelectedItem="{Binding SelectedProfile}"
                              DisplayMemberPath="Name"
                              Width="260"
                              Style="{StaticResource BabelComboBoxStyle}"
                              Visibility="{Binding Profiles.Count, Converter={StaticResource CountToVis}}" />
                    <TextBlock Text="No profiles. Go to Profiles to create one."
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               Visibility="{Binding Profiles.Count, Converter={StaticResource CountToVis}, ConverterParameter=Invert}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource BabelSectionCard}">
                <StackPanel>
                    <TextBlock Text="Tab Language Rotation"
                               Style="{StaticResource BabelFormLabel}" />
                    <TextBlock Text="Languages available when pressing Tab in the popup."
                               FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,12" />

                    <Border Background="#F7F7F7"
                            BorderBrush="#EAEAEA"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12"
                            MinHeight="60">
                        <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TabLanguageItems}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <controls:ClosableTag Content="{Binding Name}"
                                                              IsChecked="{Binding IsEnabled}"
                                                              CloseCommand="{Binding DataContext.RemoveTabLanguageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                              CloseCommandParameter="{Binding}"
                                                              Margin="0,0,6,6"
                                                              Cursor="Hand"
                                                              ToolTip="{Binding IsEnabled, StringFormat='{}{0:Enabled;Disabled}'}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>

                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                        <TextBox Text="{Binding NewLanguageInput, UpdateSourceTrigger=PropertyChanged}"
                                 Width="160"
                                 Style="{StaticResource BabelTextBoxStyle}"
                                 Margin="0,0,8,0" />    
                        <controls:BabelButton Style="{StaticResource BabelButtonPrimary}"
                                              Content="+ Add"
                                              Height="28"
                                              FontSize="12"
                                              Padding="12,0"
                                              Command="{Binding AddTabLanguageCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       FontSize="12"
                       Margin="0,0,0,12"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <controls:BabelButton Style="{StaticResource BabelButtonSecondary}"
                                      Content="Cancel"
                                      Margin="0,0,8,0"
                                      Command="{Binding CancelCommand}" />
                <controls:BabelButton Style="{StaticResource BabelButtonPrimary}"
                                      Content="Save"
                                      Command="{Binding SaveCommand}" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>