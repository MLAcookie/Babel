<Window x:Class="Babel.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Babel.Controls"
        xmlns:settings="clr-namespace:Babel.Views.Settings"
        Title="Babel Settings"
        Width="680"
        Height="600"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="#252526">
            <StackPanel>
                <TextBlock Text="BABEL"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="#888888"
                           Margin="20,20,20,16" />
                <controls:BabelNavButton Page="Home"
                                         Content="🏠  Home"
                                         Command="{Binding ShowHomeCommand}" />
                <controls:BabelNavButton Page="Profile"
                                         Content="⚙  Profiles"
                                         Command="{Binding ShowProfileConfigCommand}" />
                <controls:BabelNavButton Page="About"
                                         Content="ℹ  About"
                                         Command="{Binding ShowAboutCommand}" />
            </StackPanel>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="{StaticResource PageBackgroundBrush}">
            <Grid Margin="20">
                <settings:HomePanel Visibility="{Binding IsHomeVisible, Converter={StaticResource BoolToVis}}" />
                <settings:ProfilePanel Visibility="{Binding IsProfileConfigVisible, Converter={StaticResource BoolToVis}}" />
                <settings:AboutPanel Visibility="{Binding IsAboutVisible, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>
    </Grid>
</Window>
